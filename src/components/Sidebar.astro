---
// An array of navigation link objects. This makes it easy to add or remove links.
const navLinks = [
  { href: "/", text: "Home" },
  { href: "/friday-schedule", text: "Friday Schedule" },
];

const currentPath = Astro.url.pathname;

// Define classes for the link states, now permanently dark
const baseClasses = "block p-4 transition-colors duration-200 rounded-md m-4 font-semibold";
const inactiveClasses = "text-mist-300 hover:bg-teal-900/50 hover:text-white";
const activeClasses = "bg-teal-900 text-mist-100";
---

<aside
  id="sidebar"
  class="bg-mist-900 text-mist-100 w-64 h-screen fixed top-0 left-0 transform -translate-x-full md:translate-x-0 transition-transform duration-300 ease-in-out z-20 mt-16"
>
  <nav class="mt-6">
    {
      navLinks.map((link) => {
        const isActive = link.href === currentPath;
        return (
          <a
            href={link.href}
            class:list={[
              baseClasses,
              isActive ? activeClasses : inactiveClasses,
            ]}
          >
            {link.text}
          </a>
        );
      })
    }
  </nav>
</aside>

<style is:global>
  body.menu-open #sidebar {
    --tw-translate-x: 0;
  }
</style>
