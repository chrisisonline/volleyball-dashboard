---
// An array of navigation link objects. This makes it easy to add or remove links.
const base = import.meta.env.BASE_URL.replace(/\/$/, '')
const navLinks = [
  { href: `${base}/`, text: 'Home' },
  { href: `${base}/friday-schedule`, text: 'Friday Schedule' },
  { href: `${base}/dropin-schedule`, text: 'Drop In Schedule' },
]

const currentPath = Astro.url.pathname

// Define classes for the link states, now permanently dark
const baseClasses = 'block p-4 transition-colors duration-200 rounded-md m-4 font-semibold'
const inactiveClasses = 'text-mist-300 hover:bg-teal-900/50 hover:text-white'
const activeClasses = 'bg-teal-900 text-mist-100'
---

<aside
  id="sidebar"
  class="fixed top-0 left-0 bottom-0 z-20 mt-16 h-screen w-64 -translate-x-full transform bg-mist-900 text-mist-100 transition-transform duration-300 ease-in-out md:translate-x-0"
>
  <nav class="mt-6">
    {
      navLinks.map((link) => {
        const isActive = currentPath === link.href || currentPath === link.href.replace(/\/$/, '')
        return (
          <a
            href={link.href}
            class:list={[baseClasses, isActive ? activeClasses : inactiveClasses]}
          >
            {link.text}
          </a>
        )
      })
    }
  </nav>
</aside>

<style is:global>
  body.menu-open #sidebar {
    --tw-translate-x: 0;
  }
</style>
